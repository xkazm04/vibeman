# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
/logs
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/.claude/*
!/.claude/skills/
# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# temp files
/temp

# Windows reserved device name — Claude CLI creates this via `> nul` redirects.
# Turbopack panics when Tailwind content scanning encounters it.
nul

# database files
/database/*.db
/database/*.db-shm
/database/*.db-wal


# Conductor run artifacts
.conductor/

# Design test output
.claude-design-tests/

# vibeman-bridge VS Code extension
vibeman-bridge/node_modules/
vibeman-bridge/dist/
vibeman-bridge/*.vsix

# Tauri
/src-tauri/target/

