{
  "projectName": "vibeman",
  "createdAt": "2025-10-24T18:07:00.286Z",
  "updatedAt": "2025-10-24T18:07:00.286Z",
  "customConfig": {},
  "mcpServers": {
    "vibeman": {
      "command": "node",
      "args": ["dist/mcp-server/index.js"],
      "env": {
        "VIBEMAN_BASE_URL": "http://localhost:3000"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/hooks/task-stopped",
            "headers": {
              "X-Hook-Secret": "$VIBEMAN_HOOK_SECRET"
            },
            "allowedEnvVars": ["VIBEMAN_HOOK_SECRET"],
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/api/hooks/task-completed",
            "headers": {
              "X-Hook-Secret": "$VIBEMAN_HOOK_SECRET"
            },
            "allowedEnvVars": ["VIBEMAN_HOOK_SECRET"],
            "timeout": 10
          }
        ]
      }
    ]
  }
}