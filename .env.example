# =============================================================================
# VIBEMAN ENVIRONMENT CONFIGURATION
# =============================================================================
#
# Quick start:
#
#   1. Copy this file:    cp .env.example .env.local
#   2. Set one API key:   Uncomment ANTHROPIC_API_KEY and add your key
#   3. Start the app:     npm run dev
#
# .env.local is gitignored and will never be committed.
# All variables are read through src/lib/config/envConfig.ts.
# See SETUP.md for detailed configuration guidance.
#
# Lines starting with # are comments. Uncomment a line to activate it.
# Variables shown without # are the recommended defaults for local development.

# =============================================================================
# 1. ENVIRONMENT & RUNTIME
# =============================================================================

# NODE_ENV is set automatically by Next.js (development | production | test).
# You generally do not need to set this yourself.
# NODE_ENV=development

# Next.js server port
# PORT=3000

# Log verbosity: debug | info | warn | error (default: info in prod, debug in dev)
# LOG_LEVEL=info

# =============================================================================
# 2. LLM PROVIDER API KEYS (at least one required for AI features)
# =============================================================================

# Anthropic Claude — primary recommended provider
# ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=                      # Custom endpoint (optional)

# OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=                         # Custom endpoint (optional)

# Groq
# GROQ_API_KEY=xxx
# GROQ_BASE_URL=                           # Custom endpoint (optional)

# Ollama (local, no API key needed — just start `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434

# Internal LLM endpoint (optional — for self-hosted models behind a gateway)
# INTERNAL_API_BASE_URL=http://localhost:8080

# =============================================================================
# 3. DATABASE
# =============================================================================

# SQLite database file path (default: ./database/goals.db)
# DB_PATH=./database/goals.db

# Enable WAL mode for better concurrent read performance (default: true)
# DB_WAL_MODE=true

# Separate DB for high-frequency writes (default: auto-derived from DB_PATH)
# HOT_WRITES_DB_PATH=

# =============================================================================
# 4. APP URLs
# =============================================================================

# Public-facing URLs (NEXT_PUBLIC_ prefix makes them available client-side)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:3000
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Server-side API URL override (falls back to NEXT_PUBLIC_API_URL)
# VIBEMAN_API_URL=

# =============================================================================
# 5. FEATURE FLAGS & TUNING
# =============================================================================

# Enable API request tracking and observability dashboard (default: true)
# OBSERVABILITY_ENABLED=true

# Execution mode: local runs CLI sessions on this machine, cloud delegates to orchestrator
# EXECUTION_MODE=local                     # local | cloud

# TaskRunner tuning (all optional, sensible defaults provided)
# NEXT_PUBLIC_TR_SESSION_COUNT=4           # Number of concurrent CLI sessions
# NEXT_PUBLIC_TR_BATCH_POLL_INTERVAL_MS=10000    # Remote batch poll interval (ms)
# NEXT_PUBLIC_TR_SSE_FALLBACK_INTERVAL_MS=30000  # SSE fallback poll interval (ms)
# NEXT_PUBLIC_TR_DEFAULT_POLL_INTERVAL_MS=10000   # Default task status poll interval (ms)

# =============================================================================
# 6. SUPABASE (optional — for cloud sync between devices)
# =============================================================================

# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=xxx
# SUPABASE_SERVICE_ROLE_KEY=xxx             # Server-only — bypasses RLS

# Remote Supabase instance (optional — for multi-device message broker)
# REMOTE_SUPABASE_URL=
# REMOTE_SUPABASE_ANON_KEY=
# REMOTE_SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# 7. GITHUB PROJECTS INTEGRATION (optional — for roadmap sync)
# =============================================================================

# GITHUB_TOKEN=ghp_xxx                     # PAT with project:read and project:write scopes
# GITHUB_PROJECT_ID=PVT_xxx                # GitHub Project ID (GraphQL global ID)
# GITHUB_PROJECT_OWNER=username            # Owner username or organization
# GITHUB_PROJECT_NUMBER=1                  # Project number (visible in URL)

# Status field mapping (use /api/goals/github-sync discover endpoint to find these):
# GITHUB_STATUS_FIELD_ID=PVTSSF_xxx
# GITHUB_TARGET_DATE_FIELD_ID=PVTF_xxx
# GITHUB_STATUS_TODO_ID=xxx
# GITHUB_STATUS_IN_PROGRESS_ID=xxx
# GITHUB_STATUS_DONE_ID=xxx

# GitHub repo for social/commit features (optional):
# GITHUB_OWNER=username
# GITHUB_REPO=reponame

# =============================================================================
# 8. VOICE ASSISTANT — ANNETTE (optional)
# =============================================================================

# ELEVENLABS_API_KEY=xxx                   # ElevenLabs text-to-speech / speech-to-text

# AWS Nova Sonic (alternative voice provider):
# AWS_NOVA_ACCESS_KEY_ID=AKIA...
# AWS_NOVA_SECRET_ACCESS_KEY=xxx
# AWS_NOVA_REGION=eu-north-1

# =============================================================================
# 9. AI IMAGE GENERATION (optional)
# =============================================================================

# LEONARDO_API_KEY=xxx                     # Leonardo.ai image generation

# =============================================================================
# 10. TESTING & AUTOMATION (optional)
# =============================================================================

# BROWSERBASE_API_KEY=xxx                  # Browserbase remote browser testing
# BROWSERBASE_PROJECT_ID=xxx               # Browserbase project

# =============================================================================
# 11. SOCIAL & DISCOVERY (optional)
# =============================================================================

# GROK_API_KEY=xxx                         # Grok API (also accepts XAI_API_KEY)
# SOCIAL_ENCRYPTION_SECRET=                # Encryption secret for social credentials

# =============================================================================
# 12. OBSERVABILITY (optional)
# =============================================================================

# VIBEMAN_PROJECT_ID=                      # Project ID for observability dashboard
# VIBEMAN_URL=                             # Vibeman instance URL for onboarding

# =============================================================================
# 13. MCP SERVER (set automatically by MCP host — do not set manually)
# =============================================================================

# VIBEMAN_BASE_URL=http://localhost:3000
# VIBEMAN_PROJECT_ID=
# VIBEMAN_CONTEXT_ID=
# VIBEMAN_TASK_ID=
# VIBEMAN_PROJECT_PORT=
# VIBEMAN_RUN_SCRIPT=

# =============================================================================
# 14. CLOUD EXECUTION (optional — DAC Cloud orchestrator)
# =============================================================================

# CLOUD_ORCHESTRATOR_URL=http://localhost:3001
# CLOUD_API_KEY=
